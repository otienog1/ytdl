# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGODB_DB_NAME=your_database_name

# MongoDB Atlas URI (for export-remote-db.bat script)
MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Redis
REDIS_URL=redis://localhost:6379

# Google Cloud Storage
GCP_PROJECT_ID=your-gcp-project
GCP_BUCKET_NAME=your-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# Azure Blob Storage (Optional)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_CONTAINER_NAME=your-container-name

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1

# Email Notifications (Mailgun SMTP)
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_PORT=587
MAILGUN_SMTP_USER=postmaster@your-domain.mailgun.org
MAILGUN_SMTP_PASSWORD=your-mailgun-password
ALERT_EMAIL_FROM=noreply@yourdomain.com
ALERT_EMAIL_TO=admin@yourdomain.com

# Storage Limits
STORAGE_LIMIT_BYTES=5368709120  # 5GB in bytes

# Server
PORT=3001
ENVIRONMENT=development

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=900
RATE_LIMIT_MAX_REQUESTS=30

# File Cleanup
FILE_EXPIRY_HOURS=1  # Delete videos from GCS 1 hour after download

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# YouTube Account Configuration (Multi-Server Setup)
# Each server should have a unique account ID and its own cookies file
YT_ACCOUNT_ID=account_a
YT_DLP_COOKIES_FILE=/opt/ytdl/youtube_cookies_account_a.txt
